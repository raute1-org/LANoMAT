# Production: set APP_ENV=production and APP_DEBUG=false (never expose stack
# traces/debug info publicly), and APP_URL to the real externally-reachable
# origin (used to generate absolute URLs — Discord OAuth redirect, email
# links, etc). See README's "Production deployment" section.
APP_NAME=LANoMAT
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# host port 5434: default 5432 is taken by another local container (see compose.yml)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5434
DB_DATABASE=lanomat
DB_USERNAME=lanomat
DB_PASSWORD=lanomat

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Max size (KB) for Livewire/Filament file uploads — voice-client installers
# and M7 file-sharing exceed Livewire's 12 MB default. Must stay <= the PHP
# upload_max_filesize/post_max_size (docker/frankenphp/php.ini in prod).
LIVEWIRE_MAX_UPLOAD_KB=1048576

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# host port 6380: default 6379 is taken by another local container (see compose.yml)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ANNOUNCE_CHANNEL_ID=
DISCORD_MATCH_CATEGORY_ID=
DISCORD_MATCH_CHANNEL_CLEANUP_DELAY_MINUTES=30
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# Steam (M9, Identity+): OpenID, identity-only — STEAM_API_KEY is a Steam
# Web API key (used to fetch the profile after login), not an OAuth client
# secret. STEAM_ALLOWED_HOSTS is a comma-separated allowlist of return-to
# hosts (leave empty in dev to allow any).
STEAM_API_KEY=
STEAM_REDIRECT_URI=http://localhost:8000/settings/connections/steam/callback
STEAM_ALLOWED_HOSTS=

# Twitch (M9, Identity+): standard OAuth2 with a token refresh lifecycle —
# TWITCH_CLIENT_ID/TWITCH_CLIENT_SECRET are the app's Client ID/Secret from
# the Twitch Developer Console.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:8000/settings/connections/twitch/callback

# Reverb (websockets). REVERB_SERVER_HOST/PORT is where `reverb:start` binds
# inside the container (0.0.0.0:8080, see compose.yml's `reverb` service).
# REVERB_HOST/PORT/SCHEME is where the browser/Echo client connects — the
# non-default host port 8081 (compose maps 8081:8080; 8080 is commonly taken
# by other local dev servers, matching the postgres/redis non-default-port
# convention above).
#
# Production: set REVERB_SCHEME=https (and REVERB_PORT=443, REVERB_HOST to
# the real domain) once a TLS-terminating reverse proxy sits in front of
# Reverb (deferred to M7's Traefik setup — see README). REVERB_ALLOWED_ORIGINS
# locks the websocket handshake down to the real origin(s) the browser client
# connects from — a comma-separated list, e.g.
# "https://lan.example,https://admin.lan.example". Left unset (or `*`), any
# origin is allowed, which is fine for local dev but must be set for prod
# (see config/reverb.php).
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=*

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Mumble voice (M3, Modul 12). MUMBLE_ICE_SECRET gates the Ice interface
# (both read and write — see compose.yml's `mumble` service, which sets it
# as both `icesecretwrite` and the SuperUser password) and doubles as the
# mumble-admin sidecar's bearer token. MUMBLE_SERVER_PASSWORD is the
# LAN-internal join password for the Mumble virtual server itself (event
# participants only, not related to the Ice secret).
# Host ports: 64738 (TCP+UDP) is Mumble's own default — no local collision
# observed, kept as-is. The mumble-admin Ice-REST sidecar uses the
# non-default host port 8085 (default 8000 is commonly taken by other local
# dev servers, matching the postgres/redis/reverb convention above); the
# Laravel app talks to it over the compose network at
# http://mumble-admin:8000, not via the host port.
MUMBLE_ICE_SECRET=
MUMBLE_SERVER_PASSWORD=
MUMBLE_HOST=localhost
MUMBLE_PORT=64738
MUMBLE_ADMIN_REST_URL=http://mumble-admin:8000

# TeamSpeak voice (M8, Voice-Multiprovider). TEAMSPEAK_QUERY_PASSWORD is the
# ServerQuery query-account password (see docker/teamspeak-admin/README.md
# for how to create/scope it) — separate from TEAMSPEAK_ADMIN_TOKEN, the
# bearer token the teamspeak-admin sidecar's own REST API requires (mirrors
# MUMBLE_ICE_SECRET/MUMBLE_ADMIN_TOKEN's split above).
# Host ports: 9989 (voice, UDP) and 30033 (file transfer, TCP) are
# TeamSpeak's own defaults, no local collision observed. The
# teamspeak-admin ServerQuery-REST sidecar uses the non-default host port
# 8086 (matching mumble-admin's 8085 convention above); the Laravel app
# talks to it over the compose network at http://teamspeak-admin:8000, not
# via this port. Mode A (M8): unverified until real hardware, see
# docs/teamspeak-setup.md.
TEAMSPEAK_QUERY_PASSWORD=
TEAMSPEAK_ADMIN_TOKEN=
TEAMSPEAK_HOST=localhost
TEAMSPEAK_PORT=9987
TEAMSPEAK_ADMIN_REST_URL=http://teamspeak-admin:8000

# Pelican Panel (M6, game servers). PELICAN_APPLICATION_TOKEN is an
# Application API key (`ptla_...`, admin panel > API Credentials) used for
# server create/get/delete; PELICAN_CLIENT_TOKEN is a Client API key
# (`ptlc_...`, per-user account API key) used for power actions
# (start/stop/restart/kill) — Pelican splits these into two distinct APIs
# with two distinct token types (see docs/panel/advanced/api-docs). Task 4
# wires the actual provisioning flow; PELICAN_NODE_ID is the default node to
# create servers on when a specific node isn't chosen.
PELICAN_PANEL_URL=
PELICAN_APPLICATION_TOKEN=
PELICAN_CLIENT_TOKEN=
PELICAN_NODE_ID=
# PELICAN_MAX_RUNNING_SERVERS: optional node-wide cap on total running
# servers (all requesters combined). Bounds the automatic match-provisioning
# path, which has no requester to attribute a per-user cap to. Unset (empty)
# means unlimited.
PELICAN_MAX_RUNNING_SERVERS=

# LanCache (M7, roadmap 7.5). Parametrizes the `docker run` bootstrap
# ApplyLancacheSetup runs over SSH on a role=lancache RemoteHost (see
# docs/lancache-setup.md) — LanCache itself runs on a SEPARATE host, never
# in this repo's own compose.yml. Leave unset to use the defaults
# (lancachenet/monolithic:latest, 8.8.8.8, lancache_data) baked into
# config/services.php.
LANCACHE_IMAGE=
LANCACHE_UPSTREAM_DNS=
LANCACHE_CACHE_VOLUME=

# Own Docker registry (M7, roadmap 7.2). REGISTRY_HOST is the registry's
# host[:port] (an external registry, or the optional registry:2 Compose
# service documented in docs/registry-setup.md) — used both as the
# app-image tag prefix for a prod pull and, as a repo-level Actions
# *variable* (not this .env value), by .github/workflows/publish-images.yml
# to decide whether to run at all. REGISTRY_USERNAME/REGISTRY_PASSWORD are
# read locally for `docker login` (see docs/registry-setup.md); in CI they
# are configured as Actions *secrets* of the same name, not from this file.
REGISTRY_HOST=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Traefik v3 ingress (M7, roadmap 7.1). APP_DOMAIN is the public hostname
# routed to the `app` service (participant UI + Filament `/admin`, same
# service/router — see compose.yml's `app` labels); `ws.${APP_DOMAIN}` is
# derived automatically for `reverb-prod`'s router, no separate variable
# needed. ACME_EMAIL is the Let's Encrypt account email (required by the
# `letsencrypt` certresolver in docker/traefik/traefik.yml). On a pure-LAN
# deployment with no public DNS, leave both unset: the `app`/`reverb-prod`
# Host() rules then never match a real request, and Traefik's `websecure`
# entrypoint serves its self-signed default certificate to any client that
# connects by IP instead — see docs/traefik-setup.md for the full
# ACME-vs-self-signed decision and setup steps.
APP_DOMAIN=
ACME_EMAIL=
